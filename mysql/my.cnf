[mysqld]
# Allow connections from any IP address.
# MySQL 8.0 already defaults to 0.0.0.0, but this is made explicit so that
# the setting is visible and auditable.
#
# SECURITY NOTE: binding to 0.0.0.0 means MySQL is reachable on every
# interface of the Docker host (LAN, WAN, and VPN).  You MUST restrict
# access at the firewall level to only the VPN subnet, for example:
#
#   Zerotier  – allow TCP 3306 from 10.147.0.0/16
#   Tailscale – allow TCP 3306 from 100.64.0.0/10
#
# Alternatively you can bind to a specific VPN interface IP by replacing
# 0.0.0.0 with that IP address (e.g. bind-address = 10.147.x.x).
bind-address            = 0.0.0.0

# Performance & character set
character-set-server    = utf8mb4
collation-server        = utf8mb4_unicode_ci

[client]
default-character-set   = utf8mb4
