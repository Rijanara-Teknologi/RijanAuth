{
  "info": {
    "name": "RijanAuth API Collection",
    "description": "Comprehensive API documentation for RijanAuth Identity Server - OpenID Connect / OAuth 2.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Setup & Health",
      "item": [
        {
          "name": "System Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "health"
              ]
            },
            "description": "Check system health status"
          }
        },
        {
          "name": "OpenID Configuration (Discovery)",
          "request": {
            "method": "GET",
