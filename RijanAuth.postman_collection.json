    {
      "name": "1. OAuth 2.0 / OIDC Flows",
      "item": [
        {
          "name": "1.1 Authorization Code Flow",
          "item": [
            {
              "name": "Step 1: Get Authorization Code (Browser)",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/auth/realms/{{realm}}/protocol/openid-connect/auth?client_id={{client_id}}&redirect_uri={{redirect_uri}}&response_type=code&scope=openid profile email&state={{$randomUUID}}",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "auth",
                    "realms",
                    "{{realm}}",
                    "protocol",
                    "openid-connect",
                    "auth"
                  ],
                  "query": [
                    {
                      "key": "client_id",
                      "value": "{{client_id}}"
                    },
                    {
                      "key": "redirect_uri",
                      "value": "{{redirect_uri}}"
                    },
                    {
                      "key": "response_type",
                      "value": "code"
                    },
                    {
                      "key": "scope",
                      "value": "openid profile email"
                    },
                    {
                      "key": "state",
                      "value": "{{$randomUUID}}"
                    }
                  ]
                },
                "description": "Opens login page. After login, user is redirected to redirect_uri with authorization code"
              }
            },
            {
              "name": "Step 2: Exchange Code for Tokens",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "var jsonData = pm.response.json();",
                      "if (jsonData.access_token) {",
                      "    pm.environment.set('access_token', jsonData.access_token);",
                      "}",
                      "if (jsonData.refresh_token) {",
                      "    pm.environment.set('refresh_token', jsonData.refresh_token);",
                      "}",
                      "if (jsonData.id_token) {",
                      "    pm.environment.set('id_token', jsonData.id_token);",
                      "}",
                      "",
                      "pm.test('Status code is 200', function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test('Response contains access_token', function () {",
                      "    pm.expect(jsonData).to.have.property('access_token');",
                      "});",
                      "",
                      "pm.test('Response contains refresh_token', function () {",
                      "    pm.expect(jsonData).to.have.property('refresh_token');",
                      "});",
                      "",
                      "console.log('Access token received. You can now:');",
                      "console.log('1. Decode the access_token at https://jwt.io');",
                      "console.log('2. Use Step 3: Get UserInfo to get user claims');"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                  }
                ],
                "body": {
                  "mode": "urlencoded",
                  "urlencoded": [
                    {
                      "key": "grant_type",
                      "value": "authorization_code"
                    },
                    {
                      "key": "client_id",
                      "value": "{{client_id}}"
                    },
                    {
                      "key": "client_secret",
                      "value": "{{client_secret}}"
                    },
                    {
                      "key": "code",
                      "value": "{{authorization_code}}"
                    },
                    {
                      "key": "redirect_uri",
                      "value": "{{redirect_uri}}"
                    }
                  ]
                },
                "url": {
                  "raw": "{{base_url}}/auth/realms/{{realm}}/protocol/openid-connect/token",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "auth",
                    "realms",
                    "{{realm}}",
                    "protocol",
                    "openid-connect",
                    "token"
                  ]
                },
                "description": "Exchange authorization code for access token, refresh token, and ID token"
              }
            },
            {
              "name": "Step 3: Get UserInfo - User Claims",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 200', function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test('Response contains sub claim', function () {",
                      "    var jsonData = pm.response.json();",
                      "    pm.expect(jsonData).to.have.property('sub');",
                      "});",
                      "",
                      "var jsonData = pm.response.json();",
                      "console.log('UserInfo Response:', JSON.stringify(jsonData, null, 2));",
                      "console.log('');",
                      "console.log('\u2713 This response matches the claims in your decoded JWT token');",
                      "console.log('  (Decode your access_token at https://jwt.io to verify)');"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{access_token}}",
                    "description": "Access token from Step 2"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/auth/realms/{{realm}}/protocol/openid-connect/userinfo",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "auth",
                    "realms",
                    "{{realm}}",
                    "protocol",
                    "openid-connect",
                    "userinfo"
                  ]
                },
                "description": "Get user information (claims) using the access token from Step 2.\n\n**Response matches decoded JWT:** The claims returned here are exactly the same as the claims in your decoded JWT access token (excluding protected system claims).\n\n**To verify:**\n1. Copy the `access_token` from Step 2\n2. Decode it at https://jwt.io\n3. Compare the claims in the decoded JWT with this response\n\n**Example Response:**\n```json\n{\n  \"sub\": \"34144\",\n  \"name\": \"FARIZ NASIRUDIN\",\n  \"given_name\": \"FARIZ\",\n  \"family_name\": \"NASIRUDIN\",\n  \"preferred_username\": \"fariz\",\n  \"email\": \"fariz\",\n  \"email_verified\": true\n}\n```"
              }
            }
          ]
        },
        {
          "name": "1.2 Authorization Code Flow with PKCE",
          "item": [
            {
              "name": "Step 1: Get Authorization Code with PKCE",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "// Generate code_verifier (43-128 characters)",
                      "var code_verifier = CryptoJS.lib.WordArray.random(32).toString(CryptoJS.enc.Base64url);",
                      "pm.environment.set('code_verifier', code_verifier);",
                      "",
                      "// Generate code_challenge (S256)",
                      "var code_challenge = CryptoJS.SHA256(code_verifier).toString(CryptoJS.enc.Base64url);",
                      "pm.environment.set('code_challenge', code_challenge);"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/auth/realms/{{realm}}/protocol/openid-connect/auth?client_id={{client_id}}&redirect_uri={{redirect_uri}}&response_type=code&scope=openid profile email&state={{$randomUUID}}&code_challenge={{code_challenge}}&code_challenge_method=S256",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "auth",
                    "realms",
                    "{{realm}}",
                    "protocol",
                    "openid-connect",
                    "auth"
                  ],
                  "query": [
                    {
                      "key": "client_id",
                      "value": "{{client_id}}"
                    },
                    {
                      "key": "redirect_uri",
                      "value": "{{redirect_uri}}"
                    },
                    {
                      "key": "response_type",
                      "value": "code"
                    },
                    {
                      "key": "scope",
                      "value": "openid profile email"
                    },
                    {
                      "key": "state",
                      "value": "{{$randomUUID}}"
                    },
                    {
                      "key": "code_challenge",
                      "value": "{{code_challenge}}"
                    },
                    {
                      "key": "code_challenge_method",
                      "value": "S256"
                    }
                  ]
                },
                "description": "Authorization request with PKCE for public clients (SPAs, mobile apps)"
              }
            },
            {
              "name": "Step 2: Exchange Code with code_verifier",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "var jsonData = pm.response.json();",
                      "if (jsonData.access_token) {",
                      "    pm.environment.set('access_token', jsonData.access_token);",
                      "}",
                      "if (jsonData.refresh_token) {",
                      "    pm.environment.set('refresh_token', jsonData.refresh_token);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/x-www-form-urlencoded"
                  }
                ],
                "body": {
                  "mode": "urlencoded",
                  "urlencoded": [
                    {
                      "key": "grant_type",
                      "value": "authorization_code"
                    },
                    {
                      "key": "client_id",
                      "value": "{{client_id}}"
                    },
                    {
                      "key": "code",
                      "value": "{{authorization_code}}"
                    },
                    {
                      "key": "redirect_uri",
                      "value": "{{redirect_uri}}"
                    },
                    {
                      "key": "code_verifier",
                      "value": "{{code_verifier}}"
                    }
                  ]
                },
                "url": {
                  "raw": "{{base_url}}/auth/realms/{{realm}}/protocol/openid-connect/token",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "auth",
                    "realms",
                    "{{realm}}",
                    "protocol",
                    "openid-connect",
                    "token"
                  ]
                },
                "description": "Exchange code using code_verifier for PKCE flow"
              }
            }
          ]
        },
