        {
          "name": "Logout",
          "item": [
            {
              "name": "Logout (API - Bearer Token)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{access_token}}",
                    "type": "text"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/auth/realms/{{realm}}/protocol/openid-connect/logout",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "auth",
                    "realms",
                    "{{realm}}",
                    "protocol",
                    "openid-connect",
                    "logout"
                  ]
                },
                "description": "Logout a user via API by sending a valid access token in the Authorization header.\n\nThe server will:\n1. Decode the access token to identify the user session\n2. Mark the UserSession as LOGGED_OUT in the database\n3. Revoke all refresh tokens associated with the session\n4. Return {\"status\": \"logged_out\"}\n\nUse this endpoint from your application's logout button handler, after clearing the local session, to also invalidate the RijanAuth session on the server side."
              },
              "response": []
            },
            {
              "name": "Logout (Browser - OIDC RP-Initiated)",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/auth/realms/{{realm}}/protocol/openid-connect/logout?id_token_hint={{id_token}}&post_logout_redirect_uri={{redirect_uri}}&state={{$randomUUID}}",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "auth",
                    "realms",
                    "{{realm}}",
                    "protocol",
                    "openid-connect",
                    "logout"
                  ],
                  "query": [
                    {
                      "key": "id_token_hint",
                      "value": "{{id_token}}",
                      "description": "The ID token previously issued to the client. Used to identify the user session to terminate."
                    },
                    {
                      "key": "post_logout_redirect_uri",
                      "value": "{{redirect_uri}}",
                      "description": "URI to redirect to after logout. Must be a registered redirect URI for the client."
                    },
                    {
                      "key": "state",
                      "value": "{{$randomUUID}}",
                      "description": "Optional opaque value passed back to the client in the redirect."
                    }
                  ]
                },
                "description": "Browser-based (OIDC RP-Initiated Logout) flow.\n\nRedirect the user's browser to this endpoint to end their session. Optionally provide:\n- `id_token_hint`: The ID token to identify the session to terminate\n- `post_logout_redirect_uri`: Where to redirect after logout\n- `state`: Opaque value echoed back in the redirect\n\nIf `post_logout_redirect_uri` is omitted the response is JSON: {\"status\": \"logged_out\"}."
              },
              "response": []
            }
          ]
        }
      ]
