# True in development, False in production
DEBUG=True

FLASK_APP=run.py
FLASK_DEBUG=1

# If not provided, a random one is generated 
# SECRET_KEY=<YOUR_SUPER_KEY_HERE>

# Database configuration
# By default, SQLite is used (no configuration needed).
# To use MySQL, uncomment the variables below and set DB_ENGINE=mysql.
# RijanAuth will automatically use the PyMySQL driver when DB_ENGINE=mysql.
# DB_ENGINE=mysql
# DB_HOST=localhost
# DB_NAME=rijanauth
# DB_USERNAME=rijanauth_user
# DB_PASS=<STRONG_PASS>
# DB_PORT=3306

# Used for CDN (in production)
# No Slash at the end
ASSETS_ROOT=/static/assets

# SOCIAL AUTH Github
# GITHUB_ID=YOUR_GITHUB_ID
# GITHUB_SECRET=YOUR_GITHUB_SECRET
