# True in development, False in production
DEBUG=True

FLASK_APP=run.py
FLASK_DEBUG=1

# If not provided, a random one is generated 
# SECRET_KEY=<YOUR_SUPER_KEY_HERE>

# -----------------------------------------------------------------------
# Database configuration
# By default, SQLite is used (no configuration needed).
# To use MySQL (required when running via Docker Compose), uncomment the
# variables below and fill in the values.
# RijanAuth will automatically use the PyMySQL driver when DB_ENGINE=mysql.
# -----------------------------------------------------------------------
# DB_ENGINE=mysql
# DB_HOST=mysql
# DB_NAME=rijanauth
# DB_USERNAME=rijanauth_user
# DB_PASS=<STRONG_PASS>
# DB_PORT=3306

# -----------------------------------------------------------------------
# MySQL service credentials (used by docker-compose for the mysql container)
# These must match DB_USERNAME / DB_PASS above.
# -----------------------------------------------------------------------
# MYSQL_ROOT_PASSWORD=<STRONG_ROOT_PASS>

# -----------------------------------------------------------------------
# Docker Compose port settings (optional – defaults shown)
# -----------------------------------------------------------------------
# APP_PORT=5085
# MYSQL_PORT=3306
# MYSQL_BIND_HOST=0.0.0.0

# Used for CDN (in production)
# No Slash at the end
ASSETS_ROOT=/static/assets

# SOCIAL AUTH Github
# GITHUB_ID=YOUR_GITHUB_ID
# GITHUB_SECRET=YOUR_GITHUB_SECRET
